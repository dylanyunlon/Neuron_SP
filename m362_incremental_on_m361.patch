+# Phase 7b_lc: 7B long context seq=2049 (2-seed, 200 steps)
+# M362: --max_seq_len now supported.
+# Note: 2048 % 3 != 0 → use 2049 (3×683) for 3-GPU SP divisibility.
+echo "===== Phase 7b_lc: 7B long context seq=2049 (2-seed) ====="
+for S in 1 2; do
+    PYTHONHASHSEED=$((S * 7)) run_exp "p7b_lc_ddp_7B_s${S}" "7B" 1 "DDP" 200 1 8 "--use_ac --max_seq_len 2049"
+    PYTHONHASHSEED=$((S * 7)) run_exp "p7b_lc_desloc_7B_s${S}" "7B" 32 "DESLOC" 200 1 8 "--use_ac --max_seq_len 2049"
+done
+
+sleep 5
+python3 -c "import torch; torch.cuda.empty_cache()" 2>/dev/null
+
 # Phase 7c: 7B Nesterov vs DiLoCo (1 seed, 1536 steps)
 echo "===== Phase 7c: 7B Nesterov ====="
 PYTHONHASHSEED=7 run_exp "p7c_nesterov_7B" "7B" 32 "DESLOC" 1536 1 8 "--use_ac --outer_optimizer nesterov --outer_momentum 0.9"
