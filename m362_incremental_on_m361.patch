+    # M362: Validate max_seq_len divisibility for SP.
+    # Pattern: Megatron-LM context_parallel_size validation in transformer_config.py.
+    # SP scatters seq_len / world_size tokens per worker; indivisible
+    # lengths cause NCCL all-to-all shape mismatch → silent data corruption.
+    world_size = int(os.environ.get('WORLD_SIZE', 1))
+    if config.use_autosp and world_size > 1:
+        if config.max_seq_len % world_size != 0:
+            raise ValueError(
