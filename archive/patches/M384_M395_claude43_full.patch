+#!/usr/bin/env bash
+set -eo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+cd "$SCRIPT_DIR"
+
+eval "$(conda shell.bash hook)"
+conda activate walking3
+set -u
+
+export TORCH_NCCL_ASYNC_ERROR_HANDLING=1
+export NCCL_TIMEOUT=1800000
+export TORCH_NCCL_HEARTBEAT_TIMEOUT_SEC=1800
+export NCCL_DEBUG=WARN
+export CUDA_DEVICE_ORDER=PCI_BUS_ID
+export TORCH_NCCL_TRACE_BUFFER_SIZE=1000000
+export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
+
+RESULTS_DIR="./desloc_results"
+mkdir -p "$RESULTS_DIR"
+
+NGPU=3
+TIMESTAMP=$(date +%Y%m%d_%H%M%S)
+LOG_DIR="./logs_13B_${TIMESTAMP}"
+mkdir -p "$LOG_DIR"
+
+echo "================================================================"
+echo " DES-LOC 13B Experiment — 2×A6000 + 1×H100 NVL"
+echo " 启动: $(date)"
+echo " Memory budget: A6000=48GB, H100=96GB"
+echo " 13B BF16 model = 25.7GB → fits on A6000 with AC"
+echo " Optimizer CPU-offloaded → no GPU optimizer memory"
+echo "================================================================"
+nvidia-smi --query-gpu=index,name,memory.total --format=csv,noheader
+echo "================================================================"
+
+PORT=29500
+
+run_exp() {
+    local NAME="$1"
+    local MODEL="$2"
+    local KX="$3"
+    local METHODS="$4"
+    local STEPS="$5"
+    local BATCH="${6:-1}"
+    local GRAD_ACCUM="${7:-8}"
+    local EXTRA="${8:-}"
+
+    local KU=$((KX * 3))
+    local KV=$((KX * 6))
+    if [ "$KX" -eq 1 ]; then KU=1; KV=1; fi
+
+    echo ""
+    echo ">>> [$(date +%H:%M:%S)] $NAME | model=$MODEL Kx=$KX Ku=$KU Kv=$KV methods=$METHODS steps=$STEPS batch=$BATCH×$GRAD_ACCUM $EXTRA"
+
+    CUDA_VISIBLE_DEVICES=0,1,2 torchrun \
+        --nproc_per_node=$NGPU \
+        --master_addr=127.0.0.1 \
+        --master_port=$PORT \
+        REAL_GPU_BENCHMARK.py \
+        --model_size "$MODEL" \
+        --batch_size "$BATCH" \
+        --grad_accum "$GRAD_ACCUM" \
+        --max_steps "$STEPS" \
+        --Kx "$KX" \
+        --Ku "$KU" \
+        --Kv "$KV" \
+        --methods $METHODS \
+        --results_dir "$RESULTS_DIR" \
+        $EXTRA \
+        2>&1 | tee "${LOG_DIR}/${NAME}.log"
+
+    PORT=$((PORT + 1))
+    if [ $PORT -gt 30000 ]; then PORT=29500; fi
+}
+
+echo ""
+echo "===== Phase 0: Smoke test — 13B, 5 steps, verify OOM-free ====="
+PYTHONHASHSEED=42 run_exp \
+    "smoke_13B_desloc" "13B" 32 "DESLOC" 5 1 4 \
+    "--cpu_offload --use_ac"
+
+sleep 3
+
+echo ""
+echo "===== Phase 1: 13B DDP baseline (bs=1, Kx=1) ====="
+PYTHONHASHSEED=42 run_exp \
+    "p1_ddp_13B" "13B" 1 "DDP" 200 1 8 \
+    "--cpu_offload --use_ac"
+
+sleep 5
+
+echo ""
+echo "===== Phase 2: 13B DES-LOC Kx ablation (200 steps) ====="
+for KX in 16 32 64; do
+    PYTHONHASHSEED=42 run_exp \
+        "p2_desloc_13B_Kx${KX}" "13B" "$KX" "DESLOC" 200 1 8 \
+        "--cpu_offload --use_ac"
+    sleep 5
+done
+
+echo ""
+echo "===== Phase 3: 13B DES-LOC + AutoSP (SP saves memory → try bs=2) ====="
+for KX in 32 64; do
+    PYTHONHASHSEED=42 run_exp \
+        "p3_sp_desloc_13B_Kx${KX}" "13B" "$KX" "DESLOC" 200 1 8 \
+        "--cpu_offload --use_ac --use_autosp"
+    sleep 5
+
+    PYTHONHASHSEED=42 run_exp \
+        "p3_sp_desloc_13B_Kx${KX}_bs2" "13B" "$KX" "DESLOC" 200 2 4 \
+        "--cpu_offload --use_ac --use_autosp"
+    sleep 5
+done
+
+echo ""
+echo "===== Phase 4: 13B long-run (1536 steps, best Kx from Phase 2) ====="
+PYTHONHASHSEED=42 run_exp \
+    "p4_desloc_13B_Kx32_long" "13B" 32 "DESLOC" 1536 1 8 \
+    "--cpu_offload --use_ac"
+sleep 5
+
+PYTHONHASHSEED=42 run_exp \
+    "p4_sp_desloc_13B_Kx32_long" "13B" 32 "DESLOC" 1536 1 8 \
+    "--cpu_offload --use_ac --use_autosp"
+sleep 5
+
+echo ""
+echo "===== Phase 5: 13B Nesterov outer optimizer ====="
+PYTHONHASHSEED=42 run_exp \
+    "p5_nesterov_13B" "13B" 32 "DESLOC" 200 1 8 \
+    "--cpu_offload --use_ac --outer_optimizer nesterov --outer_momentum 0.9"
+sleep 5
+
+PYTHONHASHSEED=42 run_exp \
+    "p5_sp_nesterov_13B" "13B" 32 "DESLOC" 200 1 8 \
+    "--cpu_offload --use_ac --use_autosp --outer_optimizer nesterov --outer_momentum 0.9"
+
+echo ""
+echo "================================================================"
+echo " 13B experiments complete — $(date)"
+echo " JSON count: $(ls -1 $RESULTS_DIR/*13B*.json 2>/dev/null | wc -l)"
+echo "================================================================"
+
+python3 << 'PYEOF'
+import json, glob, statistics
+
+results = {}
+for f in sorted(glob.glob('desloc_results/*13B*.json')):
+    d = json.load(open(f))
+    cfg = d.get('config', {})
+    model = cfg.get('model_size', '?')
+    kx = cfg.get('Kx', 1)
+    steps = cfg.get('max_steps', 0)
+    if steps < 10: continue
+    for method, data in d.get('results', {}).items():
+        if not isinstance(data, dict): continue
+        loss = data.get('final_loss')
+        mfu = data.get('mfu', 0)
+        tput = data.get('tokens_per_sec', 0)
+        peak_mem = data.get('peak_memory_gb', 0)
+        if loss is None: continue
+        key = f'{method}_{model}_Kx{kx}'
+        results.setdefault(key, []).append({
+            'loss': loss, 'mfu': mfu,
+            'tput': tput, 'peak_mem': peak_mem
+        })
+
+print(f"\n{'Key':<40} {'N':>3} {'Loss':>14} {'MFU':>10} {'tok/s':>10} {'PeakGB':>8}")
+print('-' * 90)
+for key in sorted(results.keys()):
+    runs = results[key]
+    losses = [r['loss'] for r in runs]
+    mfus = [r['mfu'] for r in runs]
+    tputs = [r['tput'] for r in runs]
+    mems = [r['peak_mem'] for r in runs]
+    ml = statistics.mean(losses)
+    sl = statistics.stdev(losses) if len(losses) > 1 else 0
+    mm = statistics.mean(mfus)
+    mt = statistics.mean(tputs)
+    mp = max(mems) if mems else 0
+    print(f'{key:<40} {len(runs):>3} {ml:>7.2f}±{sl:<5.2f} {mm:>9.4f} {mt:>10.0f} {mp:>7.1f}')
+PYEOF
-- 
