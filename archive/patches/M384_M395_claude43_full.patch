+def _build_contiguous_groups(dp_size, sp_size):
+    groups = []
+    for g in range(dp_size):
+        groups.append(list(range(g * sp_size, (g + 1) * sp_size)))
+    return groups
+
+
+def _build_capability_sorted_groups(dp_size, sp_size, tier_infos):
+    sorted_ranks = sorted(
+        tier_infos.keys(),
+        key=lambda r: tier_infos[r].compute_score(),
+        reverse=True,
+    )
+    groups = [[] for _ in range(dp_size)]
+    for i, rank in enumerate(sorted_ranks):
+        gid = i % dp_size
+        groups[gid].append(rank)
+    return groups
+
+
+def _build_bandwidth_aware_groups(dp_size, sp_size, tier_infos):
+    nvlink_ranks = [r for r, t in tier_infos.items() if t.nvlink_available]
+    other_ranks = [r for r, t in tier_infos.items() if not t.nvlink_available]
+    all_sorted = nvlink_ranks + other_ranks
+    groups = [[] for _ in range(dp_size)]
+    for i, rank in enumerate(all_sorted):
+        gid = i // sp_size
+        if gid < dp_size:
+            groups[gid].append(rank)
+    return groups
+
+
+def _check_nccl_contiguous_fallback(groups, sp_size, dp_size):
+    _is_non_contiguous = any(
+        g != list(range(g[0], g[0] + sp_size)) for g in groups
+    )
+    if not _is_non_contiguous:
+        return groups
+    try:
+        nccl_ver = torch.cuda.nccl.version() if hasattr(torch.cuda, 'nccl') else (0, 0, 0)
+        nccl_ver_int = nccl_ver[0] * 10000 + nccl_ver[1] * 100 + nccl_ver[2]
+        if nccl_ver_int < 21900:
+            logger.warning(
+                f"[HeteroMesh] Non-contiguous SP groups with NCCL {nccl_ver}. "
+                f"NCCL >= 2.19.0 required. Falling back to contiguous.")
+            return _build_contiguous_groups(dp_size, sp_size)
+    except Exception:
+        pass
+    return groups
+
