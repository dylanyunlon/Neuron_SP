From 3b4dae959c26e634f4dda22fc13a2b02d51b9b14 Mon Sep 17 00:00:00 2001
From: dylanyunlon <dylanyunlong@gmail.com>
Date: Wed, 20 May 2026 03:45:20 +0000
Subject: [PATCH] M430: Print DeepSpeed import error instead of silent swallow

_DS_AVAILABLE=False causes DESLOC to fall back to _train_baseline
which has no cpu_offload support. The except Exception block was
hiding the actual import failure. Print the traceback to diagnose.

Signed-off-by: dylanyunlon <dylanyunlong@gmail.com>
---
 REAL_GPU_BENCHMARK.py | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/REAL_GPU_BENCHMARK.py b/REAL_GPU_BENCHMARK.py
index 06d4304..8de7c64 100644
--- a/REAL_GPU_BENCHMARK.py
+++ b/REAL_GPU_BENCHMARK.py
@@ -70,7 +70,10 @@ try:
         get_desloc_profiler,
     )
     _DS_AVAILABLE = True
-except Exception:
+except Exception as _ds_import_err:
+    import traceback as _tb
+    print(f"[WARNING] DeepSpeed import failed: {_ds_import_err}")
+    _tb.print_exc()
     # Standalone stubs — reproduce the exact same math, no deepspeed needed
     def desloc_comm_reduction_ratio(Kx, Ku, Kv, steps):
         """3-tier comm reduction: DDP does 3N AllReduces per step,
